{
  "name": "personal-website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/personal-website/src",
  "tags": [],
  "i18n": {
    "sourceLocale": "en",
    "locales": {
      "it": {
        "translation": "apps/personal-website/src/locale/messages.it.xlf"
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "syncGenerators": ["@juristr/nx-tailwind-sync:source-directives"],
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "dependsOn": ["blog:build"],
      "options": {
        "outputPath": "dist/apps/personal-website",
        "browser": "apps/personal-website/src/main.ts",
        "tsConfig": "apps/personal-website/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/personal-website/public"
          }
        ],
        "styles": ["apps/personal-website/src/styles.css"],
        "server": "apps/personal-website/src/main.server.ts",
        "ssr": {
          "entry": "apps/personal-website/src/server.ts"
        },
        "outputMode": "server",
        "inlineStyleLanguage": "css",
        "polyfills": ["@angular/localize/init"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "localize": true,
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "i18n-it": {
          "localize": ["it"]
        }
      }
    },
    "blog:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/generate-blog.ts",
        "cwd": "apps/personal-website"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "syncGenerators": ["@juristr/nx-tailwind-sync:source-directives"],
      "defaultConfiguration": "development",
      "configurations": {
        "production": {
          "buildTarget": "personal-website:build:production"
        },
        "development": {
          "buildTarget": "personal-website:build:development"
        },
        "i18n-it": {
          "buildTarget": "app-marketing:build:development,i18n-it"
        }
      }
    },
    "blog:serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon --watch src/content -e md --exec npx nx run personal-website:blog:build",
        "cwd": "apps/personal-website"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "personal-website:build",
        "staticFilePath": "dist/apps/personal-website/browser",
        "spa": false
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "personal-website:build",
        "outputPath": "apps/personal-website/src/locale",
        "outFile": "messages.en.xlf"
      }
    }
  }
}
